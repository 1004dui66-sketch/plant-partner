NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Storage 자동 설정(script)용 — Dashboard → Settings → API Keys → Secret key (서버 전용)
# SUPABASE_SECRET_KEY=
# 또는 SUPABASE_ACCESS_TOKEN + SUPABASE_DB_PASSWORD 조합
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# 공공데이터포털 (data.go.kr) — 플랫폼 1개, 서비스 4개
# 인증키는 4개 API 공통 1개 (Decoding). 각 API는 요청주소(URL)만 따로 둡니다.
# =============================================================================

# 공통 인증키 — 마이페이지 → Open API → 활용신청 현황 → 일반 인증키(Decoding)
DATA_GO_KR_SERVICE_KEY=

# -----------------------------------------------------------------------------
# [승인] 농촌진흥청 국립원예특작과학원_공기정화식물 조회 서비스
# 포맷: XML | 제공: 농축수산 > 국립원예특작과학원
# -----------------------------------------------------------------------------
DATA_GO_KR_AIR_PURIFYING_URL=https://apis.data.go.kr/1390804/NihhsFuriAirInfo/selectPuriAirPlantList

# -----------------------------------------------------------------------------
# [승인] 산림청 국립수목원_국가표준식물목록 조회 서비스
# 포맷: XML | 제공: 농축수산 > 산림청 국립수목원
# End Point(베이스) + Swagger operation 이름
# -----------------------------------------------------------------------------
DATA_GO_KR_STANDARD_PLANT_URL=https://apis.data.go.kr/1400119/KpniService
DATA_GO_KR_STANDARD_PLANT_OPERATION=

# -----------------------------------------------------------------------------
# [승인] 한국수목원정원관리원_백두대간 보호식물정보 서비스
# 포맷: JSON+XML | 제공: 농축수산 > 한국수목원정원관리원
# -----------------------------------------------------------------------------
DATA_GO_KR_BAEKDU_PLANT_URL=https://apis.data.go.kr/B554620/prtcPrntInfoService/getPrtcPrntInfoList

# -----------------------------------------------------------------------------
# [승인] 한국수목원정원관리원_종자자료집정보 서비스
# 포맷: JSON+XML | 제공: 농축수산 > 한국수목원정원관리원
# -----------------------------------------------------------------------------
DATA_GO_KR_SEED_BOOK_URL=https://apis.data.go.kr/B554620/srbkInfoService/getSrbkInfoList

# =============================================================================
# Google AI Studio (Gemini) — 스캔 이미지 식물 인식
# https://aistudio.google.com/apikey 에서 발급 (서버 전용)
# =============================================================================
GEMINI_API_KEY=
# GEMINI_API_KEY 대신 사용 가능
# GOOGLE_AI_API_KEY=
# 선택: gemini-2.5-flash (기본), gemini-2.0-flash 등
# GEMINI_MODEL=gemini-2.5-flash
